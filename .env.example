DATABASE_URL=postgresql://lectureseeker:changeme@localhost:5432/lectureseeker
DB_PASSWORD=changeme

SCRAPE_INTERVAL_HOURS=6

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@lectureseeker.local

# Ollama (local LLM for age group classification)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma3:4b
OLLAMA_ENABLED=true
OLLAMA_BATCH_SIZE=10
OLLAMA_TIMEOUT_MS=30000

# Nominatim geocoding (defaults to public API; set to self-hosted URL if available)
NOMINATIM_URL=https://nominatim.openstreetmap.org
